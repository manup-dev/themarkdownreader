{
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ES2022",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": [
      "node",
      "@wdio/mocha-framework",
      "wdio-vscode-service"
    ]
  },
  "include": ["e2e/**/*", "wdio.conf.ts"]
}
